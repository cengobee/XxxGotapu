<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Yöresel Market — Anadolu'nun 81 İlinden Sofranıza</title>
<meta name="description" content="81 ilden yöresel lezzetler. Üreticiden direkt sipariş. Coğrafi işaretli ürünler.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Inter:wght@400;500&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0;}
:root{
  --bg:#0D0908;--surface:#160D0A;--card:#1E1210;
  --red:#B22222;--red2:#D4342A;--red3:#8B1A1A;
  --gold:#C8922A;--gold2:#E8B84B;
  --cream:#F5ECD7;--cream2:#E8D5B0;
  --text:#F0E6D3;--muted:#8A7260;--faint:#3A2820;
  --border:#2A1A12;
}
html{scroll-behavior:smooth;}
body{background:var(--bg);color:var(--text);font-family:'Inter',sans-serif;min-height:100vh;}

/* SCROLLBAR */
::-webkit-scrollbar{width:6px;}
::-webkit-scrollbar-track{background:var(--bg);}
::-webkit-scrollbar-thumb{background:var(--red3);border-radius:3px;}

/* NAV */
#nav{display:flex;align-items:center;justify-content:space-between;padding:16px 40px;border-bottom:1px solid var(--border);background:var(--bg);position:sticky;top:0;z-index:90;}
#nav-logo{font-family:'Cormorant Garamond',serif;font-size:26px;font-weight:700;color:var(--cream);letter-spacing:1px;cursor:pointer;text-decoration:none;}
#nav-logo span{color:var(--gold);}
#nav-links{display:flex;gap:28px;align-items:center;}
.nav-link{font-size:13px;color:var(--muted);cursor:pointer;transition:color 0.15s;text-decoration:none;}
.nav-link:hover{color:var(--cream);}
#nav-actions{display:flex;gap:10px;align-items:center;}
.btn-outline{padding:7px 16px;border:1px solid var(--faint);border-radius:6px;background:transparent;color:var(--muted);font-size:12px;cursor:pointer;font-family:'Inter',sans-serif;transition:all 0.15s;}
.btn-outline:hover{border-color:var(--red);color:var(--cream);}
.btn-primary{padding:7px 18px;border:none;border-radius:6px;background:var(--red);color:#fff;font-size:12px;cursor:pointer;font-family:'Inter',sans-serif;transition:background 0.15s;}
.btn-primary:hover{background:var(--red2);}
#cart-icon{margin-left:8px;cursor:pointer;color:var(--muted);font-size:13px;transition:color 0.15s;}
#cart-icon:hover{color:var(--cream);}

/* HERO */
#hero{padding:60px 40px 40px;text-align:center;position:relative;overflow:hidden;}
#hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 70% 60% at 50% 0%, rgba(178,34,34,0.08) 0%, transparent 70%);pointer-events:none;}
#hero-eyebrow{font-size:11px;color:var(--gold);letter-spacing:3px;text-transform:uppercase;margin-bottom:14px;}
#hero-title{font-family:'Cormorant Garamond',serif;font-size:58px;font-weight:700;color:var(--cream);line-height:1.1;margin-bottom:16px;}
#hero-title span{color:var(--gold);}
#hero-sub{font-size:15px;color:var(--muted);max-width:500px;margin:0 auto 32px;line-height:1.7;}

/* SEARCH */
#search-bar{display:flex;max-width:560px;margin:0 auto 44px;background:var(--surface);border:1px solid var(--border);border-radius:12px;overflow:hidden;transition:border-color 0.2s;}
#search-bar:focus-within{border-color:var(--red);}
#search-bar input{flex:1;background:transparent;border:none;padding:15px 20px;font-size:14px;color:var(--text);outline:none;font-family:'Inter',sans-serif;}
#search-bar input::placeholder{color:var(--muted);}
#search-bar button{background:var(--red);border:none;padding:0 26px;color:#fff;font-size:13px;cursor:pointer;font-family:'Inter',sans-serif;transition:background 0.15s;white-space:nowrap;}
#search-bar button:hover{background:var(--red2);}

/* STATS */
#stats{display:flex;justify-content:center;gap:48px;margin-bottom:56px;flex-wrap:wrap;}
.stat{text-align:center;}
.stat-n{font-family:'Cormorant Garamond',serif;font-size:32px;font-weight:700;color:var(--gold);}
.stat-l{font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin-top:2px;}

/* MAIN LAYOUT */
#main{display:flex;gap:0;min-height:640px;border-top:1px solid var(--border);}

/* MAP SECTION */
#map-section{width:380px;flex-shrink:0;padding:24px;border-right:1px solid var(--border);background:var(--surface);}
#map-label{font-size:10px;color:var(--muted);letter-spacing:2px;text-transform:uppercase;margin-bottom:14px;display:flex;align-items:center;gap:7px;}
.pulse{width:7px;height:7px;border-radius:50%;background:var(--red2);display:inline-block;animation:pulse 2s infinite;}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1);}50%{opacity:0.4;transform:scale(0.8);}}
#tr-svg{width:100%;height:auto;display:block;border-radius:8px;border:1px solid var(--border);}
#map-hint{font-size:11px;color:var(--faint);margin-top:8px;text-align:center;}
#selected-il-info{margin-top:16px;padding:14px;background:var(--card);border:1px solid var(--border);border-radius:8px;display:none;}
#sil-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;}
#sil-name{font-family:'Cormorant Garamond',serif;font-size:18px;color:var(--cream);}
#sil-clear{background:none;border:none;color:var(--muted);cursor:pointer;font-size:18px;line-height:1;padding:0;}
#sil-foods{display:flex;flex-wrap:wrap;gap:5px;}
.sil-food{padding:4px 11px;border-radius:20px;font-size:11px;border:1px solid var(--faint);color:var(--muted);cursor:pointer;transition:all 0.15s;}
.sil-food:hover{background:var(--red3);border-color:var(--red);color:var(--cream);}

/* RIGHT SECTION */
#right-section{flex:1;padding:24px;min-width:0;background:var(--bg);}

/* CATEGORIES */
#cat-row{display:flex;gap:8px;margin-bottom:20px;flex-wrap:wrap;}
.cat-btn{padding:7px 15px;border-radius:20px;border:1px solid var(--border);background:transparent;color:var(--muted);font-size:12px;cursor:pointer;font-family:'Inter',sans-serif;transition:all 0.15s;white-space:nowrap;}
.cat-btn:hover{border-color:var(--red);color:var(--cream2);}
.cat-btn.active{background:var(--red3);border-color:var(--red);color:var(--cream);}

/* FILTER BAR */
#filter-bar{display:flex;align-items:center;justify-content:space-between;margin-bottom:18px;flex-wrap:wrap;gap:8px;}
#filter-info{font-size:13px;color:var(--muted);}
#filter-info strong{color:var(--cream);}
#filter-right{display:flex;align-items:center;gap:10px;}
#active-filter{font-size:11px;color:var(--gold);background:var(--faint);border:1px solid var(--red3);border-radius:20px;padding:3px 10px;display:none;align-items:center;gap:5px;}
#active-filter button{background:none;border:none;color:var(--muted);cursor:pointer;font-size:12px;padding:0;}
#sort-sel{background:var(--surface);border:1px solid var(--border);color:var(--muted);padding:6px 10px;border-radius:6px;font-size:12px;cursor:pointer;font-family:'Inter',sans-serif;outline:none;}
#sort-sel:focus{border-color:var(--red);}

/* PRODUCT GRID */
#prod-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(175px,1fr));gap:14px;}
.prod-card{background:var(--card);border:1px solid var(--border);border-radius:10px;overflow:hidden;cursor:pointer;transition:border-color 0.2s,transform 0.2s;}
.prod-card:hover{border-color:var(--red);transform:translateY(-3px);}
.pc-img{height:115px;background:var(--surface);display:flex;align-items:center;justify-content:center;font-size:40px;position:relative;}
.pc-badge2{position:absolute;top:7px;left:7px;background:var(--red3);color:var(--cream2);font-size:9px;padding:2px 7px;border-radius:4px;letter-spacing:0.5px;font-weight:500;}
.pc-body{padding:11px 13px;}
.pc-il{font-size:10px;color:var(--gold);text-transform:uppercase;letter-spacing:1px;margin-bottom:3px;}
.pc-name{font-size:13px;font-weight:500;color:var(--cream);margin-bottom:2px;line-height:1.3;}
.pc-seller{font-size:11px;color:var(--muted);margin-bottom:9px;}
.pc-bottom{display:flex;align-items:center;justify-content:space-between;margin-bottom:6px;}
.pc-price2{font-size:15px;font-weight:500;color:var(--gold);}
.pc-unit2{font-size:10px;color:var(--muted);}
.btn-cart{background:var(--red);border:none;border-radius:5px;padding:5px 11px;color:#fff;font-size:12px;cursor:pointer;font-family:'Inter',sans-serif;transition:background 0.15s;}
.btn-cart:hover{background:var(--red2);}
.pc-star{font-size:11px;color:var(--gold);}
.pc-star span{color:var(--muted);font-size:10px;}

/* EMPTY STATE */
.empty-state{color:var(--muted);font-size:14px;grid-column:1/-1;padding:60px 0;text-align:center;line-height:1.8;}
.empty-state button{margin-top:12px;padding:8px 20px;border:1px solid var(--border);border-radius:6px;background:transparent;color:var(--muted);cursor:pointer;font-family:'Inter',sans-serif;font-size:13px;}
.empty-state button:hover{border-color:var(--red);color:var(--cream);}

/* POPUP */
#popup-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.75);z-index:200;align-items:center;justify-content:center;padding:20px;}
#popup-overlay.show{display:flex;}
#popup-box{background:var(--surface);border:1px solid var(--border);border-radius:16px;width:400px;max-width:100%;padding:28px;position:relative;animation:slideUp 0.2s ease;max-height:90vh;overflow-y:auto;}
@keyframes slideUp{from{transform:translateY(24px);opacity:0;}to{transform:translateY(0);opacity:1;}}
#pop-close{position:absolute;top:16px;right:18px;background:none;border:none;color:var(--muted);font-size:20px;cursor:pointer;line-height:1;padding:2px 6px;border-radius:4px;transition:color 0.15s;}
#pop-close:hover{color:var(--cream);}
#pop-emoji{font-size:52px;text-align:center;margin-bottom:14px;display:block;}
#pop-il-badge{font-size:10px;color:var(--gold);text-transform:uppercase;letter-spacing:2px;margin-bottom:5px;}
#pop-name{font-family:'Cormorant Garamond',serif;font-size:26px;color:var(--cream);margin-bottom:4px;line-height:1.2;}
#pop-seller2{font-size:12px;color:var(--muted);margin-bottom:16px;}
#pop-desc{font-size:13px;color:var(--muted);line-height:1.75;margin-bottom:18px;padding:14px;background:var(--card);border-radius:8px;border-left:2px solid var(--red3);}
#pop-price-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;padding:12px;background:var(--card);border-radius:8px;}
#pop-price{font-size:24px;font-weight:500;color:var(--gold);font-family:'Cormorant Garamond',serif;}
#pop-rating{font-size:14px;color:var(--gold);}
#pop-actions{display:flex;gap:10px;}
#pop-actions button{flex:1;padding:11px;border-radius:8px;font-size:13px;cursor:pointer;font-family:'Inter',sans-serif;transition:all 0.15s;}
#pop-fav{background:transparent;border:1px solid var(--border);color:var(--muted);}
#pop-fav:hover{border-color:var(--red);color:var(--cream);}
#pop-buy{background:var(--red);border:none;color:#fff;}
#pop-buy:hover{background:var(--red2);}

/* CART TOAST */
#cart-toast{position:fixed;bottom:28px;right:28px;background:var(--red);color:#fff;padding:13px 22px;border-radius:8px;font-size:13px;z-index:300;display:none;animation:toastIn 0.2s ease;box-shadow:0 4px 20px rgba(0,0,0,0.3);}
@keyframes toastIn{from{transform:translateY(12px);opacity:0;}to{transform:translateY(0);opacity:1;}}

/* FOOTER */
#footer{padding:32px 40px;border-top:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px;margin-top:auto;}
#footer-logo{font-family:'Cormorant Garamond',serif;font-size:20px;color:var(--faint);}
#footer-logo span{color:var(--gold);}
#footer-links{display:flex;gap:20px;flex-wrap:wrap;}
.footer-link{font-size:12px;color:var(--faint);cursor:pointer;text-decoration:none;transition:color 0.15s;}
.footer-link:hover{color:var(--muted);}
#footer-copy{font-size:12px;color:var(--faint);}

/* MOBILE */
@media(max-width:768px){
  #nav{padding:12px 16px;}
  #nav-links{display:none;}
  #hero{padding:36px 16px 24px;}
  #hero-title{font-size:36px;}
  #stats{gap:24px;}
  #main{flex-direction:column;}
  #map-section{width:100%;border-right:none;border-bottom:1px solid var(--border);}
  #right-section{padding:16px;}
  #prod-grid{grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:10px;}
  #footer{padding:20px 16px;flex-direction:column;align-items:flex-start;}
  #search-bar{margin-bottom:28px;}
  #stats{margin-bottom:32px;}
}
@media(max-width:480px){
  #hero-title{font-size:28px;}
  #nav-actions .btn-outline{display:none;}
  #prod-grid{grid-template-columns:1fr 1fr;}
}
</style>
</head>
