let activeIl=null, activeCat="all", cartCount=0, filteredProds=[...PRODUCTS];

function scaleX(x){return x*(560/420);}
function scaleY(y){return y*(260/230);}

function renderMap(){
  const g=document.getElementById("map-dots");
  g.innerHTML="";
  ILLER.forEach(il=>{
    const cx=scaleX(il.x), cy=scaleY(il.y);
    const isActive=activeIl&&activeIl.id===il.id;
    if(isActive){
      const halo=document.createElementNS("http://www.w3.org/2000/svg","circle");
      halo.setAttribute("cx",cx);halo.setAttribute("cy",cy);
      halo.setAttribute("r",9);halo.setAttribute("fill","none");
      halo.setAttribute("stroke","#C8922A");halo.setAttribute("stroke-width","1.5");
      halo.setAttribute("opacity","0.6");
      g.appendChild(halo);
    }
    const c=document.createElementNS("http://www.w3.org/2000/svg","circle");
    c.setAttribute("cx",cx);c.setAttribute("cy",cy);
    c.setAttribute("r",isActive?6:3.5);
    c.setAttribute("fill",isActive?"#E8B84B":"#B22222");
    c.style.cursor="pointer";c.style.transition="all 0.15s";
    c.addEventListener("click",()=>selectIl(il));
    c.addEventListener("mouseenter",()=>{if(!isActive){c.setAttribute("fill","#D4342A");c.setAttribute("r","5");}});
    c.addEventListener("mouseleave",()=>{if(!isActive){c.setAttribute("fill","#B22222");c.setAttribute("r","3.5");}});
    g.appendChild(c);
    const t=document.createElementNS("http://www.w3.org/2000/svg","text");
    t.setAttribute("x",cx);t.setAttribute("y",cy-6);
    t.setAttribute("text-anchor","middle");t.setAttribute("font-size","6.5");
    t.setAttribute("fill",isActive?"#E8B84B":"#6A3020");
    t.style.pointerEvents="none";t.style.fontFamily="Inter,sans-serif";
    t.textContent=il.n;
    g.appendChild(t);
  });
}

function selectIl(il){
  if(activeIl&&activeIl.id===il.id){clearIl();return;}
  activeIl=il;renderMap();showIlInfo(il);filterProds();
}

function showIlInfo(il){
  const box=document.getElementById("selected-il-info");
  box.style.display="block";
  document.getElementById("sil-name").textContent=il.n+" İli";
  const sf=document.getElementById("sil-foods");
  sf.innerHTML="";
  il.foods.forEach(f=>{
    const btn=document.createElement("span");
    btn.className="sil-food";btn.textContent=f;
    btn.onclick=()=>{document.getElementById("search-input").value=f;doSearch();};
    sf.appendChild(btn);
  });
  const af=document.getElementById("active-filter");
  document.getElementById("active-filter-text").textContent=il.n;
  af.style.display="flex";
}

function clearIl(){
  activeIl=null;
  document.getElementById("selected-il-info").style.display="none";
  document.getElementById("active-filter").style.display="none";
  renderMap();filterProds();
}

function filterProds(){
  let prods=[...PRODUCTS];
  if(activeCat!=="all") prods=prods.filter(p=>p.cat===activeCat);
  if(activeIl) prods=prods.filter(p=>p.il===activeIl.n);
  const q=document.getElementById("search-input").value.trim().toLowerCase();
  if(q) prods=prods.filter(p=>p.name.toLowerCase().includes(q)||p.il.toLowerCase().includes(q)||p.seller.toLowerCase().includes(q));
  filteredProds=prods;
  renderProds();
}

function sortProds(){
  const s=document.getElementById("sort-sel").value;
  if(s==="price_asc") filteredProds.sort((a,b)=>a.price-b.price);
  else if(s==="price_desc") filteredProds.sort((a,b)=>b.price-a.price);
  else if(s==="rating") filteredProds.sort((a,b)=>b.rating-a.rating);
  renderProds();
}

function renderProds(){
  document.getElementById("prod-count").textContent=filteredProds.length;
  const grid=document.getElementById("prod-grid");
  if(filteredProds.length===0){
    grid.innerHTML='<div class="empty-state">Bu kriterlerde ürün bulunamadı.<br><button onclick="resetFilters()">Filtreleri Temizle</button></div>';
    return;
  }
  grid.innerHTML=filteredProds.map(p=>`
    <article class="prod-card" onclick="openProduct(${p.id})">
      <div class="pc-img">${p.emoji}<span class="pc-badge2">${p.badge}</span></div>
      <div class="pc-body">
        <div class="pc-il">${p.il}</div>
        <div class="pc-name">${p.name}</div>
        <div class="pc-seller">${p.seller}</div>
        <div class="pc-bottom">
          <div><span class="pc-price2">₺${p.price.toLocaleString('tr-TR')}</span><span class="pc-unit2"> / ${p.unit}</span></div>
          <button class="btn-cart" onclick="event.stopPropagation();quickAdd(${p.id})">+ Sepet</button>
        </div>
        <div class="pc-star">${"★".repeat(Math.floor(p.rating))}${"☆".repeat(5-Math.floor(p.rating))} <span>${p.rating.toFixed(1)}</span></div>
      </div>
    </article>
  `).join("");
}

function resetFilters(){
  activeIl=null;activeCat="all";
  document.getElementById("search-input").value="";
  document.querySelectorAll(".cat-btn").forEach(b=>b.classList.remove("active"));
  document.querySelector('.cat-btn[data-cat="all"]').classList.add("active");
  document.getElementById("selected-il-info").style.display="none";
  document.getElementById("active-filter").style.display="none";
  renderMap();filterProds();
}

function openProduct(id){
  const p=PRODUCTS.find(x=>x.id===id);if(!p)return;
  window._openProd=p;
  document.getElementById("pop-emoji").textContent=p.emoji;
  document.getElementById("pop-il-badge").textContent=p.il.toUpperCase()+" · "+p.seller;
  document.getElementById("pop-name").textContent=p.name;
  document.getElementById("pop-seller2").textContent=p.badge;
  document.getElementById("pop-desc").textContent=p.desc;
  document.getElementById("pop-price").textContent="₺"+p.price.toLocaleString('tr-TR')+" / "+p.unit;
  document.getElementById("pop-rating").textContent="★".repeat(Math.floor(p.rating))+" "+p.rating.toFixed(1);
  document.getElementById("popup-overlay").classList.add("show");
  document.body.style.overflow="hidden";
}

function closePopup(){
  document.getElementById("popup-overlay").classList.remove("show");
  document.body.style.overflow="";
}

function addToCart(){
  cartCount++;document.getElementById("cart-count").textContent=cartCount;
  closePopup();showToast();
}

function quickAdd(id){
  cartCount++;document.getElementById("cart-count").textContent=cartCount;showToast();
}

function showToast(){
  const t=document.getElementById("cart-toast");
  t.style.display="block";
  clearTimeout(window._toastTimer);
  window._toastTimer=setTimeout(()=>t.style.display="none",2200);
}

function doSearch(){filterProds();}

document.getElementById("search-input").addEventListener("keydown",e=>{if(e.key==="Enter")doSearch();});
document.getElementById("search-input").addEventListener("input",()=>{if(document.getElementById("search-input").value==="")filterProds();});

document.querySelectorAll(".cat-btn").forEach(btn=>{
  btn.addEventListener("click",()=>{
    document.querySelectorAll(".cat-btn").forEach(b=>b.classList.remove("active"));
    btn.classList.add("active");
    activeCat=btn.dataset.cat;
    filterProds();
  });
});

document.getElementById("popup-overlay").addEventListener("click",e=>{
  if(e.target===document.getElementById("popup-overlay"))closePopup();
});

document.addEventListener("keydown",e=>{if(e.key==="Escape")closePopup();});

renderMap();
filterProds();
</script>
